# Copy to .env.local (gitignored). Never commit real keys.

# OpenAI (dev server proxy for guided chat)
OPENAI_API_KEY=

# Supabase (browser client — use VITE_ prefix, not NEXT_PUBLIC_)
# Dashboard: Project Settings → API. For email auth, set Site URL + Redirect URLs under Authentication.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
