# Copy to .env.local (gitignored). Never commit real keys.

# OpenAI (dev server proxy for guided chat)
OPENAI_API_KEY=

# Supabase (browser client — use VITE_ prefix, not NEXT_PUBLIC_)
# Dashboard: Project Settings → API. For email auth, see README (Vercel + localhost redirect list).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: canonical site for email confirmation links when you need a fixed host (Vercel production env).
# Example: https://wip.vercel.app
# VITE_SITE_URL=
